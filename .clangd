CompileFlags:
  Add:
    - -I"D:\SDCC\include"
    - -I"D:\SDCC\include\mcs51"
    - -D"__SDCC=1"
    - -D"__SDCC_VERSION_MAJOR=4"
    - -D"__SDCC_VERSION_MINOR=2"
    - -D"__SDCC_VERSION_PATCH=0"
    - -D"__SDCC_mcs51=1"
  Remove: []
  CompilationDatabase: ./build/Debug
Diagnostics:
  Suppress: "*"
